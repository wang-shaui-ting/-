/* ========== 校园二手 - 简约圆角CSS变量体系 ========== */
page {
  /* 品牌色 */
  --primary: #1677ff;
  --primary-light: #e6f0ff;
  --primary-dark: #0958d9;

  /* 背景 */
  --bg: #f5f5f5;
  --white: #ffffff;

  /* 文字 */
  --text-main: #1a1a1a;
  --text-secondary: #666666;
  --text-muted: #999999;

  /* 边框 */
  --border: #eeeeee;

  /* 状态色 */
  --danger: #ff4d4f;
  --success: #52c41a;
  --warning: #faad14;

  /* 圆角规范（四级） */
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 40rpx;

  /* 阴影 */
  --shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);

  /* 字体 */
  font-family:
    -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue",
    sans-serif;
  font-size: 28rpx;
  color: var(--text-main);
  background-color: var(--bg);
  line-height: 1.6;
  box-sizing: border-box;
}
