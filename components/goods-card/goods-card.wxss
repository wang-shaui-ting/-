/* 商品卡片组件样式 */
.goods-card {
  width: calc((100vw - 64rpx) / 2);
  margin: 0 0 16rpx;
  background: var(--white);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.goods-img {
  width: 100%;
  height: 340rpx;
  background: #f0f0f0;
  display: block;
}

.goods-info {
  padding: 14rpx 16rpx 16rpx;
}

/* 卖家信息行 */
.goods-seller {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.seller-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.seller-name {
  font-size: 22rpx;
  color: #999;
  margin-left: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

.goods-title {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

.goods-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--danger);
  line-height: 1;
}

.goods-sold {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* 分类标签 */
.goods-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: rgba(22, 119, 255, 0.08);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}
