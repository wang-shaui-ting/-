/* 空状态组件样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: 28rpx;
}

.empty-btn:active {
  opacity: 0.85;
}
