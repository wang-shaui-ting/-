/* ========== 登录页样式 ========== */
.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #e6f0ff 0%, var(--bg) 60%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}

/* Logo 区域 */
.login-logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, var(--primary), #4096ff);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 12rpx 40rpx rgba(22, 119, 255, 0.25);
  margin-bottom: 36rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.login-sub {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 登录按钮区域 */
.login-btn-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--primary), #4096ff);
  border-radius: var(--radius-xl);
  border: none;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 28rpx rgba(22, 119, 255, 0.3);
  margin-bottom: 20rpx;
}

.login-btn:active {
  opacity: 0.85;
}

.login-btn-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
}

.login-tip {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 手机号按钮 */
.phone-btn {
  background: linear-gradient(135deg, #52c41a, #73d13d);
  box-shadow: 0 8rpx 28rpx rgba(82, 196, 26, 0.3);
}

/* 登录完成提示 */
.login-done-hint {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 跳过绑定 */
.skip-phone {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 16rpx;
  padding: 8rpx 20rpx;
}
