/* ========== 商品广场样式 ========== */
.page-index {
  min-height: 100vh;
  background: var(--bg);
}

/* 搜索栏外层包装 */
.search-bar-wrap {
  padding: 20rpx 24rpx;
  background: var(--white);
}

/* 分类筛选横条 */
.category-bar {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: var(--white);
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
  flex-shrink: 0;
}

.category-item.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}

/* 公告栏（跑马灯滚动） */
.notice-bar {
  width: 100%;
  height: 80rpx;
  overflow: hidden;
  background-color: #fff7e6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.notice-marquee-track {
  display: flex;
  white-space: nowrap;
  will-change: transform;
  /* 使用从右向左滚动的动画 */
  animation: scroll-right-to-left 12s linear infinite;
}

.notice-marquee-text {
  flex-shrink: 0;
  min-width: 100%; /* 确保每份文本至少占满容器宽度 */
  font-size: 28rpx;
  color: #333;
  padding-left: 40rpx; /* 可选，让文字与边缘有间距 */
}

/* 从右向左滚动：轨道整体向左平移一半的距离（即一个文本块的宽度） */
@keyframes scroll-right-to-left {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
/* 段落标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 16rpx;
  background: var(--white);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

/* 小程序码入口 */
.qrcode-entry {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: rgba(22, 119, 255, 0.08);
  border-radius: 24rpx;
}

.qrcode-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.qrcode-text {
  font-size: 24rpx;
  color: var(--primary);
}

/* 小程序码弹层 */
.qrcode-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.qrcode-popup {
  width: 540rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qrcode-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 28rpx;
}

.qrcode-img-wrap {
  width: 400rpx;
  height: 400rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.qrcode-img {
  width: 100%;
  height: 100%;
}

.qrcode-loading {
  font-size: 26rpx;
  color: var(--text-muted);
}

.qrcode-popup-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 28rpx;
}

.qrcode-close {
  font-size: 28rpx;
  color: var(--primary);
  padding: 10rpx 40rpx;
}

/* 商品网格 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 20rpx;
}
