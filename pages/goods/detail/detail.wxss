/* ========== 商品详情页样式 ========== */
.page-detail {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

.detail-swiper {
  width: 100%;
  height: 750rpx;
  background: #f0f0f0;
}

.detail-img {
  width: 100%;
  height: 100%;
}

.detail-info {
  padding: 32rpx 28rpx;
  background: var(--white);
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.detail-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.detail-sold {
  font-size: 24rpx;
  color: var(--text-muted);
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.detail-tags {
  display: flex;
  gap: 12rpx;
}

.detail-tag {
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: var(--primary);
  background: var(--primary-light);
  border-radius: var(--radius-sm);
}

/* 卖家信息 */
.detail-seller {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin: 16rpx 0;
  background: var(--white);
}

.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.seller-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.seller-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

.seller-campus {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.seller-contact {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--primary);
}

.seller-contact text {
  font-size: 24rpx;
  color: var(--primary);
}

/* 商品描述 */
.detail-desc {
  padding: 28rpx;
  background: var(--white);
}

.desc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  display: block;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 底部操作栏 */
.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: var(--white);
  border-top: 2rpx solid var(--border);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.footer-actions {
  display: flex;
  flex: 1;
  padding: 16rpx 0;
}

.footer-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.footer-buy {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 88rpx;
  margin-right: 24rpx;
  background: var(--primary);
  border-radius: var(--radius-xl);
}

.footer-buy text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.footer-buy:active {
  opacity: 0.85;
}
