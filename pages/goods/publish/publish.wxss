/* ========== 发布商品页样式 ========== */
.page-publish {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

.page-hd {
  padding: 24rpx 28rpx 12rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.form-card {
  margin: 20rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
}

.form-item {
  padding: 28rpx 28rpx;
  border-bottom: 2rpx solid var(--border);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 76rpx;
  background: var(--bg);
  border-radius: var(--radius);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--text-main);
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: var(--bg);
  border-radius: var(--radius);
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.6;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 76rpx;
  background: var(--bg);
  border-radius: var(--radius);
  padding: 0 20rpx;
  font-size: 28rpx;
}

.placeholder {
  color: var(--text-muted);
}

.arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* 图片上传 */
.upload-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.upload-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius);
  overflow: hidden;
}

.upload-img {
  width: 100%;
  height: 100%;
}

.upload-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 24rpx;
  border-radius: 50%;
}

.upload-add {
  width: 200rpx;
  height: 200rpx;
  background: var(--bg);
  border: 2rpx dashed var(--border);
  border-radius: var(--radius);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  font-size: 56rpx;
  color: var(--text-muted);
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 提交按钮 */
.submit-section {
  padding: 32rpx 24rpx;
}

.btn-disabled {
  opacity: 0.6;
  pointer-events: none;
}
