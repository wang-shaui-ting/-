<!-- 发布商品页 -->
<view class="page-publish">
  <view class="page-hd">
    <text class="page-title">{{isEdit ? '编辑商品' : '发布商品'}}</text>
  </view>
  <view class="form-card">
    <!-- 标题 -->
    <view class="form-item">
      <text class="form-label">标题</text>
      <input class="form-input" placeholder="请输入商品名称" value="{{title}}" bindinput="onTitleInput" maxlength="50" />
    </view>

    <!-- 分类 -->
    <view class="form-item">
      <text class="form-label">分类</text>
      <picker mode="selector" range="{{categoryList}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="form-picker">
          <text class="{{categoryIndex === 0 ? 'placeholder' : ''}}">{{categoryList[categoryIndex].name}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 价格 -->
    <view class="form-item">
      <text class="form-label">价格 ¥</text>
      <input class="form-input" type="digit" placeholder="0.00" value="{{price}}" bindinput="onPriceInput" bindblur="onPriceBlur" />
    </view>

    <!-- 商品描述 -->
    <view class="form-item">
      <text class="form-label">描述</text>
      <textarea class="form-textarea" placeholder="描述一下商品成色、使用情况、交易方式等..." value="{{desc}}" bindinput="onDescInput" maxlength="500" />
    </view>

    <!-- 已有图片（编辑模式） -->
    <view class="form-item" wx:if="{{isEdit && oldImages.length > 0}}">
      <text class="form-label">已有图片</text>
      <view class="upload-row">
        <view class="upload-item" wx:for="{{oldImages}}" wx:key="*this">
          <image class="upload-img" src="{{item}}" mode="aspectFill" />
        </view>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="form-item">
      <text class="form-label">{{isEdit ? '新增图片' : '图片'}}（最多6张）</text>
      <view class="upload-row">
        <view class="upload-item" wx:for="{{images}}" wx:key="*this">
          <image class="upload-img" src="{{item}}" mode="aspectFill" />
          <view class="upload-del" bindtap="onDelImage" data-index="{{index}}">✕</view>
        </view>
        <view class="upload-add" wx:if="{{images.length < 6}}" bindtap="onChooseImage">
          <text class="add-icon">+</text>
          <text class="add-text">{{images.length}}/6</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <view class="btn-primary {{submitting ? 'btn-disabled' : ''}}" bindtap="{{submitting ? '' : 'onSubmit'}}">
      <text>{{submitting ? '发布中...' : '立即发布'}}</text>
    </view>
  </view>
</view>