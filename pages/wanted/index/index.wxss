/* ========== 求购广场样式 ========== */
.page-wanted {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

/* 信息流列表 */
.feed-list {
  padding-top: 12rpx;
}

/* 悬浮发布按钮 */
.float-publish-btn {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--primary);
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.float-publish-btn:active {
  opacity: 0.85;
}

.publish-icon {
  font-size: 48rpx;
}

/* ========== 内嵌展开详情 ========== */
.expanded-detail {
  background: #fff;
  margin-top: -12rpx;
  margin-bottom: 12rpx;
  border-top: 1rpx solid var(--border);
  animation: slideDown 0.25s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    max-height: 0;
  }
  to {
    opacity: 1;
    max-height: 2000rpx;
  }
}

.detail-inner {
  padding: 24rpx;
}

.detail-content {
  padding-bottom: 16rpx;
}

.detail-text {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.8;
}

/* 预算和标签 */
.detail-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.detail-price {
  display: flex;
  align-items: center;
}

.detail-price .price-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.detail-price .price-value {
  font-size: 28rpx;
  color: #fa8c16;
  font-weight: 600;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-tag {
  font-size: 22rpx;
  background: var(--primary-light);
  color: var(--primary);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 评论区 ========== */
.comment-section {
  border-top: 1rpx solid var(--border);
  padding-top: 20rpx;
}

.comment-header {
  padding-bottom: 16rpx;
}

.comment-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

/* 评论列表 */
.comment-list {
  padding-bottom: 16rpx;
}

.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-main {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-user-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.comment-text {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.comment-actions {
  display: flex;
  gap: 24rpx;
}

.comment-action {
  font-size: 22rpx;
  color: var(--text-muted);
}

.comment-action:active {
  color: var(--primary);
}

/* 回复列表 */
.reply-list {
  margin-top: 12rpx;
  padding-left: 24rpx;
  padding-top: 12rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
}

.reply-item {
  display: flex;
  gap: 12rpx;
  padding-bottom: 12rpx;
}

.reply-item:last-child {
  padding-bottom: 0;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.reply-body {
  flex: 1;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  margin-right: 12rpx;
}

.reply-text {
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.5;
}

/* 空评论 / 加载 */
.comment-empty,
.comment-loading {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 评论输入栏 */
.comment-input-bar {
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.reply-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 12rpx;
  font-size: 22rpx;
  color: var(--primary);
}

.reply-cancel {
  color: var(--text-muted);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.comment-submit {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: var(--primary);
  border-radius: 36rpx;
}

.comment-submit text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.comment-submit:active {
  opacity: 0.85;
}

.detail-loading {
  text-align: center;
  padding: 60rpx 0;
  font-size: 24rpx;
  color: var(--text-muted);
}
