/* 我的发布 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

/* 商品网格 */
.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 16rpx 20rpx 0;
}

.goods-item {
  width: calc((100vw - 64rpx) / 2);
  margin: 0 0 16rpx;
}

/* 操作按钮行 */
.goods-actions {
  display: flex;
  justify-content: space-around;
  padding: 10rpx 0 6rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 6rpx 0;
}

.action-edit {
  color: var(--primary);
}

.action-del {
  color: var(--danger);
}
