<!-- 我的发布 -->
<view class="page">
  <cmp-empty-state
    wx:if="{{!loading && goodsList.length === 0}}"
    text="暂无发布的商品"
    showBtn="{{true}}"
    btnText="去发布"
    bind:action="onPublishTap"
  />
  <view class="goods-grid" wx:if="{{goodsList.length > 0}}">
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="id">
      <cmp-goods-card goods="{{item}}" bind:tap="onGoodsTap" />
      <view class="goods-actions">
        <text class="action-btn action-edit" data-id="{{item.id}}" bindtap="onEditTap">✎ 编辑</text>
        <text class="action-btn action-del" data-id="{{item.id}}" bindtap="onDeleteTap">✕ 删除</text>
      </view>
    </view>
  </view>
  <cmp-load-more loading="{{loading}}" />
</view>
