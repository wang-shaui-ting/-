/* ========== 个人中心 ========== */
.page-profile {
  min-height: 100vh;
  background: var(--bg);
}

/* 顶部用户卡片 */
.profile-header {
  background: var(--white);
  overflow: hidden;
  padding-bottom: 32rpx;
}

.profile-bg {
  height: 260rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff, #69b1ff);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-user {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -80rpx;
  position: relative;
  z-index: 1;
}

.profile-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid var(--white);
  overflow: hidden;
  background: #e8e8e8;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-top: 20rpx;
}

.profile-bio {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* 数据统计 */
.profile-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 32rpx;
  padding: 0 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--border);
}

/* 菜单区域 */
.menu-section {
  margin-top: 20rpx;
}

.menu-card {
  background: var(--white);
  border-radius: var(--radius);
  margin: 0 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid var(--border);
}

.menu-item:active {
  background: #fafafa;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: var(--text-main);
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 退出登录 */
.logout-section {
  padding: 48rpx 24rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: var(--white);
  border-radius: var(--radius-xl);
  border: 2rpx solid #ff4d4f;
}

.logout-btn text {
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.logout-btn:active {
  background: #fff2f0;
}
