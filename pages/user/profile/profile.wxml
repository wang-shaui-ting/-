<!-- 个人中心 -->
<view class="page-profile">
  <!-- 顶部用户信息卡片 -->
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-user">
      <view class="profile-avatar-wrap">
        <image class="profile-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      </view>
      <text class="profile-nickname">{{userInfo.nickname}}</text>
      <text class="profile-bio">{{userInfo.bio}}</text>
    </view>
    <!-- 数据统计 -->
    <view class="profile-stats">
      <view class="stat-item">
        <text class="stat-num">{{userInfo.followCount}}</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{userInfo.fansCount}}</text>
        <text class="stat-label">粉丝</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{userInfo.likeCount}}</text>
        <text class="stat-label">获赞</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <cmp-menu-item
        wx:for="{{menuList}}"
        wx:key="id"
        icon="{{item.icon}}"
        text="{{item.name}}"
        bind:tap="onMenuTap"
        data-id="{{item.id}}"
      />
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <cmp-menu-item
        wx:for="{{settingList}}"
        wx:key="id"
        icon="{{item.icon}}"
        text="{{item.name}}"
        bind:tap="onMenuTap"
        data-id="{{item.id}}"
      />
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="onLogoutTap">
      <text>退出登录</text>
    </view>
  </view>
</view>